{
  "name": "contafacil",
  "version": "1.0.0",
  "description": "Programa de contabilidad de escritorio - ContaFácil",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "ContaFácil",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4"
  },
  "build": {
    "appId": "com.contafacil.app",
    "productName": "ContaFácil",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es_ES", "en_US"],
      "language": "1034"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "data/**/*",
      "node_modules/**/*"
    ]
  }
}
